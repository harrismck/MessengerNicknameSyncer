{
  "Discord": {
    "BotToken": "<YOUR TOKEN HERE (or in environment variables)>",
    "NicknameSyncChannelId": "1234567891234567891",
    "NicknameClearBehavior": "ResetToFirstName", // Or ClearCompletely or DoNothing
    "ResyncMessageCount": 2000,
    "Authorization": {
      "MappingManagement": {
        "AllowedRoleIds": [
          "1234567891234567891", // Admins role
          "9123456789123456789" // Moderators role
        ],
        "AllowedUserIds": [
          "123456789123456789" // Server admin's user ID (fallback)
        ]
      },
      "ChannelRename": {
        "AllowedRoleIds": [],
        "AllowedUserIds": []
      },
      "InfoCommands": {
        "AllowedRoleIds": [],
        "AllowedUserIds": [],
        "AllowEveryone": true
      }
    },
    "AutoRenameChannels": {
      "Enabled": true,
      "ChannelIds": [
        "1234567891234567891",
        "1234567891234567891",
        "1234567891234567891"
      ],
      "RequireAuthorization": true
    },
    "FacebookBridge": {
      // Optional: Discord user ID of the bridge bot that relays unsynced Facebook users.
